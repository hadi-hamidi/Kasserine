# Database
MONGODB_URI=mongodb://localhost:27017/alkasserine
# أو استخدم MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/alkasserine

# Server
PORT=5000
NODE_ENV=development

# JWT Secret
JWT_SECRET=your_super_secret_key_here_change_in_production

# Admin Credentials (للمرة الأولى)
ADMIN_EMAIL=admin@alkasserine.com
ADMIN_PASSWORD=Admin123!@#

# Frontend URL
FRONTEND_URL=http://localhost:3000
